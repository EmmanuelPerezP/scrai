# dependencies
node_modules/
.pnpm-store/

# build output
dist/
build/
.next/
out/
*.tsbuildinfo

# NOTE: the generated API client (packages/api-client/src/generated/) and the
# OpenAPI spec (packages/api-client/openapi.json) are intentionally committed so
# Docker/CI image builds are self-contained (no DB needed to regenerate them).
# Refresh them with `pnpm generate:api` after changing the backend API.

# env
.env
.env.local
.env.*.local
*.env

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# terraform
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.*
infra/terraform/*.tfvars
!infra/terraform/*.tfvars.example
infra/terraform/.terraform.lock.hcl
crash.log

# os / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# uploads (local)
uploads/
