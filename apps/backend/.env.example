NODE_ENV=development
PORT=4000

# Postgres
DATABASE_URL=postgres://scrai:scrai@localhost:5432/scrai
# Auto-create schema from entities (fine for dev / this interview project; use migrations in prod)
DATABASE_SYNCHRONIZE=true
# Seed mock patients on boot if the patients table is empty
DATABASE_RUN_SEED=true
# Enable TLS for the DB connection (required by managed Postgres like AWS RDS)
DATABASE_SSL=false

CORS_ORIGIN=http://localhost:3000

# AWS / S3 — LocalStack defaults for local dev
AWS_REGION=us-east-1
S3_BUCKET=scrai-audio
S3_ENDPOINT=http://localhost:4566
S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# AI: "stub" (default) | "openai"
AI_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_SUMMARY_MODEL=gpt-4o-mini
