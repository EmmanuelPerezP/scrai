{
  "name": "@scrai/api-client",
  "version": "0.1.0",
  "private": true,
  "description": "Typed API client generated from the backend OpenAPI spec",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "orval --config ./orval.config.ts",
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist src/generated",
    "lint": "echo \"(generated client — lint skipped)\""
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "react": ">=18"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@types/react": "^18.3.10",
    "orval": "^8.19.0",
    "react": "^18.3.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4"
  }
}
