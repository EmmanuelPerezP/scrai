# Root reference env. Each app also has its own .env.example.
# Copy what you need into apps/backend/.env and apps/frontend/.env.local

# ---- Backend ----
PORT=4000
DATABASE_URL=postgres://scrai:scrai@localhost:5432/scrai
DATABASE_SYNCHRONIZE=true
DATABASE_RUN_SEED=true
CORS_ORIGIN=http://localhost:3000

# AWS / S3 (LocalStack defaults for local dev)
AWS_REGION=us-east-1
S3_BUCKET=scrai-audio
S3_ENDPOINT=http://localhost:4566
S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# AI provider: "stub" | "openai" (wired in a later step)
AI_PROVIDER=stub
OPENAI_API_KEY=

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
